{
  "version": "3.0.0",
  "project_name": "Advanced Tape Restorer v3.0",
  
  "restoration": {
    "field_order": "Auto-Detect",
    "qtgmc_preset": "Slow",
    "frame_rate": "Double (Default)",
    "source_filter": "Auto",
    
    "crop_top": "0",
    "crop_bottom": "0",
    "crop_left": "0",
    "crop_right": "0",
    
    "denoise_strength": "None",
    "denoise_device": "CPU (BM3D - Recommended)",
    "gpu_device_id": "0",
    
    "fix_chroma_shift": false,
    "sharpen_strength": "None",
    "deband_enabled": false,
    "deband_strength": "Medium",
    
    "remove_artifacts": false,
    "artifact_filter": "TComb",
    
    "use_ai_upscaling": false,
    "ai_upscaling_engine": "realesrgan",
    "ai_upscaling_model_id": "realesrgan_x2plus",
    
    "aspect_ratio_mode": "Keep (Default)",
    "resize_width": "1440",
    "resize_height": "1080",
    "resize_mode": "Letterbox (Pad)",
    "resize_algorithm": "Bicubic"
  },
  
  "ai_models": {
    "model_root": "%LOCALAPPDATA%\\Advanced_Tape_Restorer\\ai_models",
    "commercial_mode": true,
    "auto_download": true,
    "huggingface_token": "",
    "available_upscaling_engines": [
      "realesrgan",
      "basicvsrpp",
      "swinir",
      "znedi3"
    ],
    "available_interpolation_engines": [
      "rife",
      "dain",
      "film",
      "amt"
    ],
    "enable_colorization": false,
    "colorization_engine": "deoldify",
    "enable_face_enhancement": false,
    "enable_forensic_cleaning": false
  },
  
  "encoding": {
    "codec": "libx264 (H.264, CPU)",
    "crf": "18",
    "ffmpeg_preset": "slow",
    "audio": "Copy Audio",
    "audio_codec": "AAC",
    "audio_bitrate": "192k"
  },
  
  "capture": {
    "analog": {
      "resolution": "720x480",
      "framerate": "29.97",
      "codec": "huffyuv",
      "pixel_format": "yuv422p",
      "audio_channels": 2
    },
    "dv": {
      "format": "dv",
      "codec": "copy"
    }
  },
  
  "detection": {
    "idet_probe_frames": 900,
    "idet_prog_dom_ratio": 1.5,
    "idet_prog_min": 150,
    "idet_field_dom_ratio": 1.3,
    "idet_field_min": 80,
    "idet_field_fallback_min": 200
  },
  
  "interface": {
    "enable_notifications": true,
    "auto_save_presets": true,
    "debug_logging": false,
    "live_preview_enabled": false
  }
}
